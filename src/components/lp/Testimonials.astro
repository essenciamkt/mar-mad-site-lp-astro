---
const testimonials = [
  { text: 'Fico grato por uma das primeiras Empresa abrir as portas pra mim que sou micro Empreendedor obrigado Mar Mad Madeiras por te carinho e atenção quando vou ai fazer minhas compras na loja', name: 'Sergio Henrique da Silva', stars: 5, img: '/testimonials/sergio-henrique.png' },
  { text: 'Empresa super indico pois tem funcionários muito aplicados em especial nossa vendedora Luzimar.', name: 'Bruno Fortirio', stars: 5, img: '/testimonials/bruno-fortirio.png' },
  { text: 'Excelente atendimento e bons preços nos Materiais... Vendedora Alexia tá de Parabéns.', name: 'Daniel Souza', stars: 5, img: '/testimonials/daniel-souza.png' },
  { text: 'Ótima loja, variedade de produtos e preços acessíveis. Atendimento excelente!', name: 'Maria Santos', stars: 5, img: '' },
  { text: 'Atendimento de excelência prestado pela vendedora Luzimar. Atenciosa e com enorme conhecimento dos produtos da loja. Sempre atenciosa mesmo meu orçamento sendo muito pequeno.. Parabéns pela sua funcionária!!', name: 'Fernando Abdel', stars: 5, img: '/testimonials/fernando-abdel.png' },
  { text: 'Ótimo atendimento, ótimo material! Empresa comprometida, Atendente Luzimar muito comprometida e resolveu minhas necessidades!', name: 'Rosana Coutinho', stars: 5, img: '/testimonials/rosana-coutinho.png' },
];
---
<section class="px-4 py-16 md:px-8 md:py-24 lg:px-16 bg-section-light">
  <div class="max-w-7xl mx-auto scroll-fade">
    <div class="text-center mb-12">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-foreground mb-4">Quem Confia na Mar Mad Recomenda</h2>
      <p class="text-muted-foreground max-w-2xl mx-auto">Veja o que nossos clientes dizem sobre nossa qualidade, atendimento e comprometimento.</p>
    </div>
    <div class="relative">
      <button id="prev-btn" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 z-10 w-10 h-10 bg-primary text-white rounded-full flex items-center justify-center hover:opacity-90 transition-opacity" aria-label="Anterior">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <div class="overflow-hidden px-8">
        <div id="testimonial-track" class="grid md:grid-cols-3 gap-6 transition-opacity duration-300">
          {testimonials.slice(0, 3).map(t => (
            <div class="bg-white border border-gray-200 rounded-xl p-6">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary mb-4"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
              <p class="text-muted-foreground text-sm mb-6 min-h-[80px]">{t.text}</p>
              <div class="flex items-center gap-3">
                {t.img
                  ? <img src={t.img} alt={t.name} class="w-10 h-10 rounded-full object-cover" loading="lazy" />
                  : <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center"><span class="font-heading font-bold text-foreground text-sm">{t.name.charAt(0)}</span></div>
                }
                <div>
                  <p class="font-heading font-semibold text-sm text-foreground">{t.name}</p>
                  <div class="flex gap-0.5">
                    {'★★★★★'.slice(0, t.stars).split('').map(() => <span class="text-yellow-400 text-sm">★</span>)}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <button id="next-btn" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 z-10 w-10 h-10 bg-primary text-white rounded-full flex items-center justify-center hover:opacity-90 transition-opacity" aria-label="Próximo">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
    <div id="dots" class="flex justify-center gap-2 mt-6">
      <button class="w-6 h-2.5 rounded-full bg-primary transition-all" data-page="0"></button>
      <button class="w-2.5 h-2.5 rounded-full bg-gray-300 transition-all" data-page="1"></button>
    </div>
  </div>
</section>

<script define:vars={{ testimonials }}>
  const ITEMS = 3;
  const pages = Math.ceil(testimonials.length / ITEMS);
  let current = 0;
  const track = document.getElementById('testimonial-track');
  const dots = document.querySelectorAll('#dots button');

  function render(page) {
    const slice = [];
    for (let i = 0; i < ITEMS; i++) slice.push(testimonials[(page * ITEMS + i) % testimonials.length]);
    track.style.opacity = '0';
    setTimeout(() => {
      track.innerHTML = slice.map(t => `
        <div class="bg-white border border-gray-200 rounded-xl p-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:hsl(152,55%,38%);margin-bottom:1rem"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
          <p style="color:#6b7280;font-size:.875rem;margin-bottom:1.5rem;min-height:80px">${t.text}</p>
          <div style="display:flex;align-items:center;gap:.75rem">
            ${t.img ? `<img src="${t.img}" alt="${t.name}" style="width:40px;height:40px;border-radius:50%;object-fit:cover" loading="lazy">` : `<div style="width:40px;height:40px;border-radius:50%;background:#f3f4f6;display:flex;align-items:center;justify-content:center;font-weight:700">${t.name.charAt(0)}</div>`}
            <div><p style="font-weight:600;font-size:.875rem">${t.name}</p><span style="color:#facc15">★★★★★</span></div>
          </div>
        </div>`).join('');
      track.style.opacity = '1';
    }, 300);
    dots.forEach((d, i) => {
      d.style.width = i === page ? '1.5rem' : '.625rem';
      d.style.background = i === page ? 'hsl(152,55%,38%)' : '#d1d5db';
    });
    current = page;
  }

  document.getElementById('prev-btn')?.addEventListener('click', () => render((current - 1 + pages) % pages));
  document.getElementById('next-btn')?.addEventListener('click', () => render((current + 1) % pages));
  dots.forEach(d => d.addEventListener('click', () => render(+d.dataset.page)));
  setInterval(() => render((current + 1) % pages), 6000);
</script>
