---
const motivos = [
  { icon: 'award', title: 'TRADIÇÃO E EXPERIÊNCIA', desc: 'Temos 25 anos de experiência no ramo de madeiras e somos uma das maiores madeireiras do RJ!' },
  { icon: 'truck', title: 'ENTREGAS RÁPIDAS', desc: 'Foco em atender de forma rápida e eficiente cada cliente.' },
  { icon: 'credit-card', title: 'PAGAMENTO FACILITADO', desc: 'Parcelamos suas compras em até 10x sem juros no cartão. Para lojas de materiais de construção, consulte condições especiais.' },
  { icon: 'message-circle', title: 'O MELHOR ATENDIMENTO', desc: 'Vendedores com foco em solução para os clientes e em constante treinamento para sempre prestar um excelente atendimento!' },
  { icon: 'settings', title: 'MULTICANAL DE COMPRAS', desc: 'Você pode optar por realizar a sua compra na loja ou realizar toda operação pelo telefone. Consulte nossa equipe de vendas!' },
  { icon: 'check-square', title: 'QUALIDADE GARANTIDA', desc: 'Selecionamos as melhores marcas e os melhores fornecedores para sempre oferecer, a você cliente, produtos de qualidade!' },
];

const icons: Record<string, string> = {
  award: '<path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"/><circle cx="12" cy="8" r="6"/>',
  truck: '<path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v3"/><rect width="7" height="7" x="14" y="10" rx="1"/><circle cx="17.5" cy="17.5" r="2.5"/><circle cx="6.5" cy="17.5" r="2.5"/>',
  'credit-card': '<rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/>',
  'message-circle': '<path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"/>',
  settings: '<path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>',
  'check-square': '<polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>',
};
---
<section class="section-green-gradient py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-8">
    <h2 class="text-2xl md:text-3xl font-heading font-bold text-center text-white mb-12 uppercase">
      6 MOTIVOS PARA COMPRAR NA MAR MAD
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {motivos.map(m => (
        <div class="motivo-card scroll-fade">
          <div class="flex justify-center mb-3 text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[m.icon]} />
          </div>
          <h3 class="font-heading font-bold text-sm uppercase tracking-wide mb-2 text-foreground">{m.title}</h3>
          <div class="w-8 h-0.5 bg-primary mx-auto mb-3"></div>
          <p class="text-muted-foreground text-sm leading-relaxed">{m.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
