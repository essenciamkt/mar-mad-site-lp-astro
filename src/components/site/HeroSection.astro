<section class="relative min-h-[400px] md:min-h-[500px] flex items-center">
  <img
    src="/images/hero-bg.jpg"
    alt="Madeira de qualidade"
    class="absolute inset-0 w-full h-full object-cover"
    fetchpriority="high"
    width="1920"
    height="500"
  />
  <div class="absolute inset-0" style="background:linear-gradient(to right,rgba(0,0,0,.6),rgba(22,101,52,.5))"></div>
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-8 py-16 md:py-24">
    <h1 class="font-heading text-4xl md:text-6xl font-bold text-white leading-tight mb-4 max-w-2xl uppercase">
      MADEIRA PAIXÃO<br />TRADIÇÃO
    </h1>
    <p class="text-white/90 text-lg md:text-xl font-body italic mb-6">
      Atendemos todo Rio de Janeiro
    </p>
  </div>
</section>
